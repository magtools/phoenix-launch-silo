STRESS_PROFILE_NAME=catalog-search-stress
STRESS_TYPE=stress
STRESS_SCENARIO_SCRIPT=scenarios/catalog-search.js
STRESS_EXECUTOR=ramping-arrival-rate
STRESS_RATE=60
STRESS_TIME_UNIT=1m
STRESS_PRE_ALLOCATED_VUS=30
STRESS_MAX_VUS=220
STRESS_STAGES=120:2m,250:3m,500:5m,0:2m
STRESS_SCENARIOS=catalog=80,search=20
STRESS_SEARCH_PATH=/catalogsearch/result/?q=
STRESS_SEARCH_TERMS=shirt,shoe,jacket,bag
STRESS_URL_ORDER=random
STRESS_URL_REVISIT_RATE=4
STRESS_CUSTOMER_SECTION_LOAD_MODE=always
STRESS_CUSTOMER_SECTION_LOAD_PATH=/customer/section/load
