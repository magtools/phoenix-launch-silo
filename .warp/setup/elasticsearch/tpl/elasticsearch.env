# Elasticsearch
ES_VERSION=2.19.5
ES_MEMORY=1g
ES_PASSWORD=XmsES_MEMORY++99

# Canonical SEARCH Configuration
SEARCH_MODE=local
SEARCH_ENGINE=opensearch
SEARCH_VERSION=2.19.5
SEARCH_IMAGE=opensearchproject/opensearch:2.19.5
SEARCH_SCHEME=http
SEARCH_HOST=elasticsearch
SEARCH_PORT=9200
SEARCH_CONTAINER_USER=opensearch
SEARCH_CONTAINER_CONFIG_PATH=/usr/share/opensearch/config/opensearch.yml
SEARCH_DATA_PATH=/usr/share/opensearch/data
SEARCH_SERVER_BIN=/usr/share/opensearch/bin/opensearch
SEARCH_PLUGIN_BIN=/usr/share/opensearch/bin/opensearch-plugin
SEARCH_HOST_CONFIG_FILE=./.warp/docker/config/opensearch/opensearch.yml
SEARCH_INSTALL_PHONETIC_PLUGIN=1
